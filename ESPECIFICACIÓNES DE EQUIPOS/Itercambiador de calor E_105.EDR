          <arrayvalue source="Default" value="  Distance l2 = F - l1                                    l2 = 2.875 in" text="" />
          <arrayvalue source="Default" value="  Linear load, Omega = Fu/(l1+0.5*l2)                  Omega = 26.4 psi" text="" />
