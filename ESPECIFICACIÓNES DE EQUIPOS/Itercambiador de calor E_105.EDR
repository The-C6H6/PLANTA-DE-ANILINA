      <array name="DetTubesheets">
        <uom></uom>
        <values>
          <arrayvalue source="Default" value="Component: Front Tubesheet      Design of Stationary and Floating Tubesheets" text="" />
          <arrayvalue source="Default" value="ASME VIII-2 (VIII-1 UHX) 2023  4.18.9 Fig. 4.18.11(d)" text="" />
          <arrayvalue source="Default" value="Controlling Case: Table 4.18.7 (1)" text="" />
          <arrayvalue source="Default" value="Tubesheet material:        SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Tube material:             SA-214 K01807 Wld. tube" text="" />
          <arrayvalue source="Default" value="Shell material:            SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Channel material:          SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Adjacent shell material:   -" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Design temp. tubesheet T = 420 F        Design temp. tubes    Tt = 420 F" text="" />
          <arrayvalue source="Default" value="Design temp. shell    Ts = 420 F        Design temp. channel  Tc = 160 F" text="" />
          <arrayvalue source="Default" value="Shell metal tmp/TubS T's = 292.1 F      Channel metal tmp TS T'c = 90.5 F" text="" />
          <arrayvalue source="Default" value="TubSh metal tmp at rim T'= 144.5 F      Tubesheet OD           A = 12.3125 in" text="" />
          <arrayvalue source="Default" value="TubSh mod.elasticity   E = 27779998 psi Shell mod.elasticity  Es = 27779998 psi" text="" />
          <arrayvalue source="Default" value="Channel mod.elast.    Ec = 28984616 psi Tube mod.elas. at Tt  Et = 27779998 psi" text="" />
          <arrayvalue source="Default" value="TubSh allowable stress S = 20000 psi    Tube mod.elas. at T  Ett = 27779998 psi" text="" />
          <arrayvalue source="Default" value="Tube yield stress    Syt = 22000 psi    Tube allow.Str. at Tt St = 13412 psi" text="" />
          <arrayvalue source="Default" value="Tube exp.depth ratio rho = 1            Tube allow.Str. at T Stt = 13412 psi" text="" />
          <arrayvalue source="Default" value="Tube expanded depth  ltx = 0.4375 in    Eff.tube side groove h'g = 0.0625 in" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness    h = 0.4375 in    Unsupported tube span  l = 12.219 in" text="" />
          <arrayvalue source="Default" value="Tube buckling factor   k = 0.8          Unsupp.length lt=k*l  lt = 9.7752 in" text="" />
          <arrayvalue source="Default" value="Center-to-center dis  UL = 1.75 in      Tube pitch             p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="Pass partition groove hg = 0.1875 in    Tube outside diam.    dt = 1.125 in" text="" />
          <arrayvalue source="Default" value="Tube side cor.allow.  ct = 0.125 in     Shell side cor.allow. cs = 0.125 in" text="" />
          <arrayvalue source="Default" value="Tube projection      tpr = 0.125 in     Tube corrosion allow.  c = -" text="" />
          <arrayvalue source="Default" value="Outermost tube rad.   ro = 3.6305 in    Tube thickness        tt = 0.083 in" text="" />
          <arrayvalue source="Default" value="Shell all. stress     Ss = 20000 psi    Channel all. stress   Sc = 20000 psi" text="" />
          <arrayvalue source="Default" value="Adj Shell all. str. Ss,1 = -            Gasket diam G1        G1 = -" text="" />
          <arrayvalue source="Default" value="Gasket shell diameter Gs = 11.9375 in   Gasket channel diam.  Gc = 11.9375 in" text="" />
          <arrayvalue source="Default" value="Shell radius          as = 5.9688 in    Channel radius        ac = 5.9688 in" text="" />
          <arrayvalue source="Default" value="Shell thickness       ts = 0.1875 in    Channel thickness     tc = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Adjacent shell thk  ts,1 = -            Channel ID            Dc = 10.386 in" text="" />
          <arrayvalue source="Default" value="Shell ID              Ds = 10.386 in    Tube length L         L  = 94.625 in" text="" />
          <arrayvalue source="Default" value="Number of tubes       Nt = 20           Tube length Lt        Lt = 95.5 in" text="" />
          <arrayvalue source="Default" value="Bolt circle            C = 13.5625 in   Flange load           W* = 8775 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness    h = 0.4375 in    Actual tubesheet thk  ha = 1.0 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Shell design pressure Ps = 50 psi       Tube design pressure Pt  = 50 psi" text="" />
          <arrayvalue source="Default" value="Shell vacuum press.  Psv = 0 psi        Tube vacuum press.  Ptv  = 0 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="*Shell th.ex.coe.alpha's = 6.8842       *Chan.th.ex.coe.alpha'c  = 6.4683" text="" />
          <arrayvalue source="Default" value="*TubSh th.ex.coe. alpha' = 6.589           *(*10**6) in/in/F" text="" />
          <arrayvalue source="Default" value="Poisson's ratio shell vs = 0.3          Poisson's rat. tubes  vt = 0.3" text="" />
          <arrayvalue source="Default" value="Poisson's rat.channel vc = 0.3          Poisson's rat. tubSh   v = 0.3" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Table 4.18.6  Select W* for configuration (d) and design" text="" />
          <arrayvalue source="Default" value="              loading case 1" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  W* = Wdc    = 8775 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 1.  Determine Do, Mu, Mu* and h'g from 4.18.6.4(a)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Do = 2 * ro + dt                                                     (4.18.2)" text="" />
          <arrayvalue source="Default" value="     = 2 *3.6305 + 1.125                                     Do = 8.386 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  mu = (p - dt) / p                                                    (4.18.3)" text="" />
          <arrayvalue source="Default" value="     = (1.4062 - 1.125) / 1.4062                             mu = 0.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  d* = MAX[(dt-2*tt*(Ett/E)*(Stt/S)*Rho),(dt-2*tt)]                    (4.18.5)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  = MAX[(1.125- 2*0.083*(27779998/27779998)*( 13412 / 20000 )*   1  ) ," text="" />
          <arrayvalue source="Default" value="        (1.125- 2*0.083)]" text="" />
          <arrayvalue source="Default" value="                                                             d* = 1.0137 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Actual pass lane area, AL                                  AL = 14.68 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  p* = p/SQRT(1-(4*MIN[AL,4*Do*p]/Pi*Do**2))                           (4.18.6)" text="" />
          <arrayvalue source="Default" value="     = 1.4062/SQRT(1-(4*MIN[ AL , 4* 8.386 *1.4062]/Pi* 8.386 **2))" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                             p* = 1.641 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  mu*= (p* - d*) / p*                                                  (4.18.7)" text="" />
          <arrayvalue source="Default" value="     = ( 1.641 - 1.0137)/1.641                              mu* = 0.3823" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  h'g = MAX[(hg-ct),0.0]                                               (4.18.8)" text="" />
          <arrayvalue source="Default" value="      = MAX[0.1875- 0.125 ) , 0.0]                          h'g = 0.0625 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                      * h'g = 0 for Operating Load Cases" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate ao, ac, as, rhos, rhoc, xs, and xt" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  ao  = Do/2                                                         (4.18.157)" text="" />
          <arrayvalue source="Default" value="      =  8.386 /2                                            ao = 4.193 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  as  = Gs/2                     Configuration (d)                   (4.18.159)" text="" />
          <arrayvalue source="Default" value="      = 11.9375/2                                            as = 5.9688 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  ac  = Gc/2                     Configuration (d)                   (4.18.162)" text="" />
          <arrayvalue source="Default" value="      = 11.9375/2                                            ac = 5.9688 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  rhos= as/ao                                                        (4.18.164)" text="" />
          <arrayvalue source="Default" value="      = 5.9688 / 4.193                                     rhos = 1.4235" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  rhoc= ac/ao                                                        (4.18.165)" text="" />
          <arrayvalue source="Default" value="      = 5.9688 / 4.193                                     rhoc = 1.4235" text="" />
          <arrayvalue source="Default" value="  xs  = 1-Nt(dt/2*ao)**2                                             (4.18.166)" text="" />
          <arrayvalue source="Default" value="      = 1- 20 (1.125/ 2* 4.193 )**2                          xs = 0.6401" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  xt  = 1-Nt((dt-2*tt)/2*ao)**2                                      (4.18.167)" text="" />
          <arrayvalue source="Default" value="      = 1- 20 ((1.125- 2*0.083)/ 2* 4.193 )**2               xt = 0.7384" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 2.  Calculate the shell and channel coefficients" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) The shell coefficients for Configuration (d)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                    beta_s = k_s = lambda_s = delta_s = 0" text="" />
          <arrayvalue source="Default" value="(b) The channel coefficients for Configuration (d)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                    beta_c = k_c = lambda_c = delta_c = 0" text="" />
          <arrayvalue source="Default" value="                                  zeta_c = 0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                  CC = CmDelta = CmTheta = CqDelta = CqTheta = 1" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 3.  Calculate h/p and Parameter Xa." text="" />
          <arrayvalue source="Default" value="                  Determine E*/E and v* using paragraph 4.18.6.4(b)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    Layout: Square" text="" />
          <arrayvalue source="Default" value="    Tubesheet thickness    h = 0.4375 in    Tube pitch        p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="    h/p factor           h/p = 0.3111       mu* factor      mu* = 0.3823" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value=" From table 4.18.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    E*/E factor         E*/E = 0.5186       v* factor        v* = 0.1923" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    Effective Tubesheet Modulus of Elasticity                E* = 14405349 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Xa = [(24*(1-(v*)**2)*Nt*Et*tt*(dt-tt)*ao**2)                      (4.18.183)" text="" />
          <arrayvalue source="Default" value="           / ((E*)*L*h**3)]**0.25" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = [(24*(1-(0.1923 )**2)* 20 *27779998 *0.083*(1.125-0.083)* 4.193 **2)" text="" />
          <arrayvalue source="Default" value="        / ( 14405349 *94.625 *0.4375 **3)]**0.25" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                             Xa = 3.616" text="" />
          <arrayvalue source="Default" value=" Using Xa, Determine Psi1, Psi2, Za, Zd, Zv, Zw, and Zm" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Psi1(Xa)=bei(Xa)+(1-v*)/Xa*ber'(Xa)                  Psi1(Xa) = 1.7606" text="" />
          <arrayvalue source="Default" value="  Psi2(Xa)=ber(Xa)-(1-v*)/Xa*bei'(Xa)                  Psi2(Xa) = -1.5366" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Za = bei'(Xa)*Psi2(Xa)-ber'(Xa)*Psi1(Xa)                   Za = 4.033" text="" />
          <arrayvalue source="Default" value="  Zd = (ber(Xa)*Psi2(Xa)+ bei(Xa)*Psi1(Xa))/(Xa**3*Za)       Zd = 0.0333" text="" />
          <arrayvalue source="Default" value="  Zv = (ber'(Xa)*Psi2(Xa)+ bei'(Xa)*Psi1(Xa))/(Xa**2*Za)     Zv = 0.0825" text="" />
          <arrayvalue source="Default" value="  Zw = (ber'(Xa)*ber(Xa)+ bei'(Xa)*bei(Xa))/(Xa**2*Za)       Zw = 0.0825" text="" />
          <arrayvalue source="Default" value="  Zm = (ber'(Xa)**2+bei'(Xa)**2)/(Xa*Za)                     Zm = 0.4421" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 4.  Calculate the following parameters" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  K  = A/Do                                                          (4.18.184)" text="" />
          <arrayvalue source="Default" value="     = 12.3125/  8.386                                        K = 1.468" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  F  = ((1-v*)/E*)*(lambda_s+lambda_c+E*Ln(K))                       (4.18.185)" text="" />
          <arrayvalue source="Default" value="     = ((1-0.1923)/ 14405349  )*(    0   +    0    + 27779998*Ln(1.468))" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                              F = 0.598" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Phi= (1+v*)*F                                                      (4.18.186)" text="" />
          <arrayvalue source="Default" value="     = (1+0.1923)*0.598                                     Phi = 0.7132" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q1 = (rhos-1-Phi*Zv)/(1+Phi*Zm)                                    (4.18.187)" text="" />
          <arrayvalue source="Default" value="     = (1.4235-1-0.7132*0.0825)/(1+0.7132*0.4421)            Q1 = 0.2772" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 5.  Calculate the following quantities" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) Calculate omega_s, omega_s*, omega_c, and omega_c*" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_s = rhos*k_s*beta_s*delta_s*(1+h*beta_s)                     (4.18.188)" text="" />
          <arrayvalue source="Default" value="   = 1.4235*   0  *   0  *    0    *(1+ 0.4375  *   0  )" text="" />
          <arrayvalue source="Default" value="                                                        omega_s = 0.0 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_s*= ((ao**2*(rhos**2-1)*(rhos-1))/4)-omega_s                 (4.18.189)" text="" />
          <arrayvalue source="Default" value="   = (( 4.193 **2*(1.4235**2-1)*(1.4235-1))/4)-0.0" text="" />
          <arrayvalue source="Default" value="                                                        omega_s*= 1.9105 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_c = rhoc*k_c*beta_c*(delta_c*(CmDelta + CqDelta*h*beta_c)" text="" />
          <arrayvalue source="Default" value="          -zeta_c*(CmTheta/beta_c + h*CqTheta/2)                     (4.18.190)" text="" />
          <arrayvalue source="Default" value="   = 1.4235*   0   *   0  *(    0    *(1 + 1*0.4375*   0  ) - 0" text="" />
          <arrayvalue source="Default" value="                                                        omega_c = 0.0 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_c*= ao**2[((rhoc**2+1)*(rhoc-1))/4 - (rhos-1)/2]-omega_c     (4.18.191)" text="" />
          <arrayvalue source="Default" value="   =  4.193 **2[((1.4235**2+1)*(1.4235-1))/4 - (1.4235-1)/2]-0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                        omega_c*= 1.9105 in2" text="" />
          <arrayvalue source="Default" value="(b) Calculate gamma_b For Configuration (d)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  gamma_b = (Gc-Gs)/Do                                               (4.18.195)" text="" />
          <arrayvalue source="Default" value="          = (11.9375-11.9375)/8.386                      gamma_b = 0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 6.  Calculate the effective pressure Pe" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Pe = Ps-Pt                                                         (4.18.198)" text="" />
          <arrayvalue source="Default" value="     =   0   -  50                                            Pe = -50 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 7.  For each loading case check the bending stress" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) Calculate Q2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q2 = [(omega_s*)(Ps)-(omega_c*)(Pt)+(gamma_b*(W*))/2*Pi] /         (4.18.201)" text="" />
          <arrayvalue source="Default" value="         (1+Phi*Zm)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = [( 1.9105  )(  0  )-( 1.9105  )( 50  )+(  0.0  * 8775 )/2*Pi] /" text="" />
          <arrayvalue source="Default" value="         (1+0.7132*0.4421)" text="" />
          <arrayvalue source="Default" value="                                                             Q2 = -72.63" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(b) Pe not equal to zero, calculate Q3" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q3 = Q1 + 2*(Q2)/(Pe*ao**2)                                        (4.18.202)" text="" />
          <arrayvalue source="Default" value="     = 0.2772 +2*(  -72.63  )/(   -50   *  4.193 **2)        Q3 = 0.4425" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Determine coefficient Fm (Tbl. 4.18.3 or Fig. 4.18.7 and 4.18.8), where" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                  Controlling x = 3.1102 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation functions Psi1 and Psi2 relative to x" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Psi1(x) = bei(x) + (1-v*)/x * ber'(x)                 Psi1(x) = 1.5821" text="" />
          <arrayvalue source="Default" value="  Psi2(x) = ber(x) - (1-v*)/x * bei'(x)                 Psi2(x) = -0.6148" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate Functions Qm, Qv, and Fm relative to x" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Qm(x) = [bei'(Xa)*Psi2(x)-ber'(Xa)*Psi1(x)]/Za          Qm(x) = 0.9496" text="" />
          <arrayvalue source="Default" value="  Qv(x) = [Psi1(Xa)*Psi2(x)-Psi2(Xa)*Psi1(x)]/(Xa*Za)     Qv(x) = 0.0925" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Fm(x) = [Qv(x) + Q3*Qm(x)] / 2" text="" />
          <arrayvalue source="Default" value="        = [Qv3.1102) + (0.4425 )*Qm3.1102)] / 2           Fm(x) = 0.2563" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Fm = MAX|Fm(x)|                                            Fm = 0.2563" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate the tubesheet bending stress" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigma = Pe*(1.5*Fm/mu*)*(2*ao/(h-h'g))**2                          (4.18.203)" text="" />
          <arrayvalue source="Default" value="        =    -50   *(1.5*0.2563/0.3823)*(2* 4.193 /0.4375 -0.0625))**2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                          sigma = -25149 psi" text="" />
          <arrayvalue source="Default" value="(c) Acceptance Criteria" text="" />
          <arrayvalue source="Default" value="                                                       |sigma| &lt;= 1.5*S" text="" />
          <arrayvalue source="Default" value="                                                     25149 psi &lt;= 30000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 8. Calculate the average shear stress in the tubesheet at" text="" />
          <arrayvalue source="Default" value="                 the outer edge of the perforated region, if required" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  taua = min[0.8*S, 0.533*Sy]" text="" />
          <arrayvalue source="Default" value="  taua = min[0.8*  20000  , 0.533* 34504.8 ]               taua = 16000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Ligament efficiency, mu                                    mu = 0.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="      |Pe|    &lt;= 2*mu*h/ao*taua" text="" />
          <arrayvalue source="Default" value="      |Pe|    &lt;= 2*0.2 0.4375/  4.193  *  16000" text="" />
          <arrayvalue source="Default" value="    50 psi    &lt;=  667.68 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 9.  Check the tube stress and tube-to-tubesheet joint design" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) Check the axial tube stress" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(1) Determine coefficients Ft,min and Ft,max (Table 4.18.4) and calculate" text="" />
          <arrayvalue source="Default" value="    the extreme tube stresses sigmat,1 and sigmat,2 (values can be + or -)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Zd(x) = [Psi2(Xa)*ber(x) + Psi1(Xa)*bei(x)] / Za*Xa**3" text="" />
          <arrayvalue source="Default" value="  Zw(x) = [ber'(Xa)*ber(x) + bei'(Xa)*bei(x)] / Za*Xa**2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Ft(x) = [Zd(x) + Q3*Zw(x)]*(Xa**4)/2               valid 0 &lt;= x &lt;= Xa" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Ft,min = MIN[Ft(x)]                                    Ft,min = -2.4992" text="" />
          <arrayvalue source="Default" value="  Ft,max = MAX[Ft(x)]                                    Ft,max = 5.9749" text="" />
          <arrayvalue source="Default" value="When Pe is not equal to zero" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigmat,1 = [(Ps*xs - Pt*xt) - Pe*Ft,min]/(xt-xs)                   (4.18.205)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="      = [((  0 )*0.6401 - ( 50 )*0.7384) -   -50  *( -2.4992)] /" text="" />
          <arrayvalue source="Default" value="          (0.7384-0.6401)" text="" />
          <arrayvalue source="Default" value="                                                       sigmat,1 = -1645 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigmat,2 = [(Ps*xs - Pt*xt) - Pe*Ft,max]/(xt-xs)                   (4.18.206)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="      = [((  0 )*0.6401 - ( 50 )*0.7384) -   -50  *( 5.9749 )] /" text="" />
          <arrayvalue source="Default" value="          (0.7384-0.6401)" text="" />
          <arrayvalue source="Default" value="                                                       sigmat,2 = 2661 psi" text="" />
          <arrayvalue source="Default" value="(2) Determine sigmat,max" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigmat,max = MAX(|sigmat,1|,|sigmat,2|)                            (4.18.209)" text="" />
          <arrayvalue source="Default" value="             = MAX(|  -1645 |,|  2661  |)            sigmat,max = 2661 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(b) Acceptance Criteria" text="" />
          <arrayvalue source="Default" value="                                                     sigmat,max &lt; St" text="" />
          <arrayvalue source="Default" value="                                                       2661 psi &lt; 13412 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(c) Check the tube-to-tubesheet joint design" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(1) Calculate the largest tube-to-tubesheet joint load, Wt" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Wt = sigmat,max*Pi*(dt-tt)tt                                       (4.18.210)" text="" />
          <arrayvalue source="Default" value="     = 2661 *Pi*(1.125-0.083)*0.083                          Wt = 723 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(2) Determine the maximum allowable load for the tube-to-tubesheet" text="" />
          <arrayvalue source="Default" value="    joint design, Lmax" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  UW-18(d) max load      = -" text="" />
          <arrayvalue source="Default" value="  UW-20    max load      = -" text="" />
          <arrayvalue source="Default" value="  UW-20 max No test load = 2551 lbf" text="" />
          <arrayvalue source="Default" value="  UW-20 max    test load = 3280 lbf" text="" />
          <arrayvalue source="Default" value="                                                           Lmax = 2551 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(3) Acceptance Criteria" text="" />
          <arrayvalue source="Default" value="                                                            Wt &lt;= Lmax" text="" />
          <arrayvalue source="Default" value="                                                       723 lbf &lt;= 2551 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(f) Check the tubes for buckling" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(1) Calculate the largest equivalent unsupported buckling length, lt" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Tube buckling factor    k = 0.8" text="" />
          <arrayvalue source="Default" value="  Unsupported tube span   l = 12.219 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  lt = k*l                                                           (4.18.211)" text="" />
          <arrayvalue source="Default" value="     = 0.8 * 12.219                                          lt = 9.7752 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(2) Determine the maximum permissible buckling stress limit, Stb, for the tubes" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  rt = SQRT[dt**2+(dt-2*tt)**2]/4                                    (4.18.217)" text="" />
          <arrayvalue source="Default" value="     = SQRT[(1.125)**2 + (1.125-2*0.083)**2)/4               rt = 0.3696 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Ft = lt/rt                                                         (4.18.216)" text="" />
          <arrayvalue source="Default" value="     = 9.7752 /0.3696                                        Ft = 27.6679" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Ct = SQRT[(2*Et*Pi**2)/Syt]                                        (4.18.215)" text="" />
          <arrayvalue source="Default" value="     = SQRT[(2*27779998*Pi**2)/ 22000]                       Ct = 157.8773" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="When Pe is not equal to zero" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Fs = MAX[(3.25-0.25(Zd+Q3*Zw)*Xa**4) , 1.25]                       (4.18.218)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = MAX[(3.25-0.25(0.0333+(0.4425 )*0.0825)*3.616**4) , 1.25]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = MAX[ (0.2626 ) , (1.25)]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                 (Fs need not be &gt; 2.0)                      Fs = 1.25" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="For Ct &gt; Ft" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Stb = MIN[ (Syt/Fs)*(1-Ft/2*Ct) , (St) ]                           (4.18.213)" text="" />
          <arrayvalue source="Default" value="      = MIN[ ( 22000 / 1.25 )*(1- 27.6679/2*157.8773) , ( 13412) ]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                            Stb = 16058 psi" text="" />
          <arrayvalue source="Default" value="(3) Determine sigmat,min" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigmat,min = MIN[ sigmat,1 , sigmat,2 ]                            (4.18.220)" text="" />
          <arrayvalue source="Default" value="             = MIN[   -1645  ,   2661   ]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                     sigmat,min = -1645 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(4) Acceptance Criteria" text="" />
          <arrayvalue source="Default" value="                                                  |sigmat,min| &lt;= Stb" text="" />
          <arrayvalue source="Default" value="                                                      1645 psi &lt;= 16058 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Units: Pressure/stress: psi       Distance: in" text="" />
          <arrayvalue source="Default" value="Controlling case:                 ***" text="" />
          <arrayvalue source="Default" value="  Load case                        1          2          3          4" text="" />
          <arrayvalue source="Default" value="  Factor Q2                       -73        73          0          0" text="" />
          <arrayvalue source="Default" value="  Flange load, W*                8775       8233       8775         0" text="" />
          <arrayvalue source="Default" value="  Factor Q3                      0.442      0.442        0          0" text="" />
          <arrayvalue source="Default" value="  Factor Fm                      0.256      0.256      0.066      0.066" text="" />
          <arrayvalue source="Default" value="  Tube-side press, Pt             50          0         50          0" text="" />
          <arrayvalue source="Default" value="  Shell-side press, Ps             0         50         50          0" text="" />
          <arrayvalue source="Default" value="  Effective press., Pe            -50        50          0          0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  TubSh Bending str.            -25149      25149        0          0" text="" />
          <arrayvalue source="Default" value="  Max TubSh Bend. st             30000      30000      30000      30000" text="" />
          <arrayvalue source="Default" value="  Min TubSh thk                 0.4058     0.4058     0.0626       0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  TubSh Shear stress             -596        596         0          0" text="" />
          <arrayvalue source="Default" value="  Max TubSh Shear str            16000      16000      16000      16000" text="" />
          <arrayvalue source="Default" value="  Min TubSh thk                 0.0788     0.0788     0.0625       0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Tubesheet thickness           0.4375     0.4375     0.4375     0.4375" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tube stress" text="" />
          <arrayvalue source="Default" value="  Load case                        1          2          3          4" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Tube-side press, Pt             50          0         50          0" text="" />
          <arrayvalue source="Default" value="  Shell-side press, Ps             0         50         50          0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Factor Fs                      1.25       1.25       1.25       1.25" text="" />
          <arrayvalue source="Default" value="  Tube stress sigmat,o           2661       -2711       -50         0" text="" />
          <arrayvalue source="Default" value="  Tube stress sigmat,1           -1645      1595        -50         0" text="" />
          <arrayvalue source="Default" value="  Tube stress sigmat,2           2661       -2711       -50         0" text="" />
          <arrayvalue source="Default" value="  Maximum tube stress            13412      13412      13412      13412" text="" />
          <arrayvalue source="Default" value="  Maximum buckling stress        13412      13412      13412      13412" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Calculation of Tubesheet Temperature" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Heat Transfer Coefficients on Tubesheet" text="" />
          <arrayvalue source="Default" value="           Shell-side face     hs = 120.5 Btu/(ft2*h*F)" text="" />
          <arrayvalue source="Default" value="           Tube-side face      ht = 1105.7 Btu/(ft2*h*F)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet thermal conductivity  k = 34.6 Btu/(ft*h*F)" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness             L = 0.0365 ft         or L = 0.4375 in" text="" />
          <arrayvalue source="Default" value="Tubes pitch                     p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="Tubes inside diameter           d = 0.959 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Metal heat transfer coefficient, unpierced plate, hm = k/L = 948.8 Btu/(ft2*h*F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Layout cross sectional area, a = p**2-Pi/4*d**2               a = 1.255 in2" text="" />
          <arrayvalue source="Default" value="Inside surface of tubes bounding a ligament, A = Pi*d*L       A = 1.318 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Factor K = SQRT(A/a * ht/hm)                                  K = 1.106" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Fin effectiveness of tubesheet ligament, eta" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="         A    [1 + (A/a*K) * TANH(K)]" text="" />
          <arrayvalue source="Default" value="  eta = --- * [---------------------]                       eta = 0.955" text="" />
          <arrayvalue source="Default" value="        a*K   [ (A/a*K) + TANH(K)   ]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet Temperature Profile" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Maximum temperature of shell side fluid, Ts               Ts = 354.2 F" text="" />
          <arrayvalue source="Default" value="   Maximum temperature of tube  side fluid, Tt               Tt = 95 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet temperature (pierced section)" text="" />
          <arrayvalue source="Default" value="   Metal temperature at shell side face" text="" />
          <arrayvalue source="Default" value="     To = Tt + (Ts - Tt) / (1 + Eta * (ht / hs))             To = 121.6 F" text="" />
          <arrayvalue source="Default" value="   Metal temperature at tube side face" text="" />
          <arrayvalue source="Default" value="     TL = Tt + F * (Ts - Tt) / (1 + Eta * (ht / hs))         TL = 103.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Tubesheet temperature T = MAX[To,TL]             (pierced) T = 121.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Tubesheet mean metal temperature" text="" />
          <arrayvalue source="Default" value="     Tmean = Tt+(Ts-Tt)*(Eta-F)/((A/a)*(1+Eta*(ht/hs)))   Tmean = 224.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet rim temperature (unpierced ring)" text="" />
          <arrayvalue source="Default" value="   Metal temperature at shell side face" text="" />
          <arrayvalue source="Default" value="     To = Tt+(Ts-Tt)/(1+(ht/hs)*(1/(1+ht/hm)))               To = 144.5 F" text="" />
          <arrayvalue source="Default" value="   Metal temperature at tube side face" text="" />
          <arrayvalue source="Default" value="     TL = Tt+(Ts-Tt)/((1+ht/hm)+(ht/hs))                     TL = 117.9 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Rim temperature T = MAX[To,TL]                 (unpierced) T = 144.5 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tube-To-TubSh Joint: 'i' - Expanded with 2 grooves" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Load case                        1          2          3          4" text="" />
          <arrayvalue source="Default" value="  Wt, tube-TS Load, lbf           723        737        14          -" text="" />
          <arrayvalue source="Default" value="  Allowable no-test              2551       2551       2551         -" text="" />
          <arrayvalue source="Default" value="  Allowable test                 3280       3280       3280         -" text="" />
          <arrayvalue source="Default" value="  Factor k                         1          1          1          -" text="" />
          <arrayvalue source="Default" value="  Max load K*At*Sa               3644       3644       3644         -" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Allowable Loads per ASME VIII-1 2023 -------         UW-20" text="" />
          <arrayvalue source="Default" value="                                               No Test              Test" text="" />
          <arrayvalue source="Default" value="Type      Joint description                 fr    Lmax        fr    Lmax" text="" />
          <arrayvalue source="Default" value="  a   Welded, size (0.7af+ag) &gt;= t           0       0         1    3644" text="" />
          <arrayvalue source="Default" value="  b   Welded, size (0.7af+ag) &lt;  t           0       0        0.7   2551" text="" />
          <arrayvalue source="Default" value="  e   Welded &amp; exp., size (0.7af+ag) &gt;= t   0.8   2915         1    3644" text="" />
          <arrayvalue source="Default" value="  f   Welded &amp; exp.with 2 gr.(0.7af+ag)&lt;t  0.75   2733       0.95   3462" text="" />
          <arrayvalue source="Default" value="  g   Welded &amp; exp.with 1 gr.(0.7af+ag)&lt;t  0.65   2369       0.85   3097" text="" />
          <arrayvalue source="Default" value="  h   Welded &amp; exp.with 0 gr.(0.7af+ag)&lt;t   0.5   2004        0.7   2551" text="" />
          <arrayvalue source="Default" value="  i   Expanded with 2 grooves               0.7   2551        0.9   3280" text="" />
          <arrayvalue source="Default" value="  j   Expanded with 1 groove               0.65   2369        0.8   2915" text="" />
          <arrayvalue source="Default" value="  k   Expanded with no grooves              0.5   1822        0.6   2186" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="* = Load calculated exceeds code allowable for this joint type." text="" />
          <arrayvalue source="Default" value="For joints types a,b,c,d,e     :        Lmax = k*At*Sa*fr" text="" />
          <arrayvalue source="Default" value="For joints types f,g,h,        :        Lmax = MIN[k*At*Sa*fre,k*At*Sa]" text="" />
          <arrayvalue source="Default" value="For joints types i,j,k         :        Lmax = MIN[k*At*Sa*fe*fr*fy*ft,k*At*Sa]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Cross-sectional area  At = 0.2717 in2   Tube allowable stress Sa = 13412 psi" text="" />
          <arrayvalue source="Default" value="Max stress St = At*Sa St = 3644 psi" text="" />
          <arrayvalue source="Default" value="Tubesheet yield str. Stt = 34505 psi    Tube yield stress    Stu = 23603 psi" text="" />
          <arrayvalue source="Default" value="fe = (ltx/do or 1)    fe = 1            Min Yield Str. (Stt,Stu) = 23603 psi" text="" />
          <arrayvalue source="Default" value="ft = (Po+Pt)/Po       ft = 1            fy = Stt/Stu             = 1.46" text="" />
          <arrayvalue source="Default" value="ft = used             ft = 1            fy = used (0&lt;fy&lt;=1)   fy = 1" text="" />
          <arrayvalue source="Default" value="Tube OD               do = 1.125 in     Tube ID               di = 0.959 in" text="" />
          <arrayvalue source="Default" value="Tube thickness         t = 0.083 in     Tube mean radius      Rm = 0.521 in" text="" />
          <arrayvalue source="Default" value="TubSh mean metal tmp   T = 224.6 F      Ambient temperature Tamb = 70 F" text="" />
          <arrayvalue source="Default" value="Tubes Mod.Elasticity EtT = 27779998 psi TubSh Mod.Elast.     EsT = 28677000 psi" text="" />
          <arrayvalue source="Default" value="Tubes Coef.Th.Exp.(*) at = 6.7492       TubSh Coef.Th.Exp.(*) as = 6.7492" text="" />
          <arrayvalue source="Default" value="(*)=*10**-6 in/in/F                     fre=MAX[fe,fr,fy,ft,fr(b)]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tube expanding pressure:" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Pe = Stu*(t+do/2*(Stt/Stu))/(t+do/2)*(1.945-1.384*(di/do))    Pe = 25331 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tube to tube hole interfacial pressure:" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Po = Pe*(1-(di/do)^2)-(2/(3^0.5))*Stu*ln(do/di)               Po = 2573 psi" text="" />
          <arrayvalue source="Default" value="Pt = (Rm/do)*EtT*(at*do*(T-Tamb)-as*do*(T-Tamb))/" text="" />
          <arrayvalue source="Default" value="     (do^2/t - Rm + Rm*(2.9*(EtT/EsT)-0.3))                   Pt = 0 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="           For joint types i, j, k:                     Po + Pt &lt;= 0.58*SigmaM" text="" />
          <arrayvalue source="Default" value="                                                       2573 psi &lt;= 13690 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="??????" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Component: Rear Tubesheet       Design of Stationary and Floating Tubesheets" text="" />
          <arrayvalue source="Default" value="ASME VIII-2 (VIII-1 UHX) 2023  4.18.9 Fig. 4.18.12(C)" text="" />
          <arrayvalue source="Default" value="Controlling Case: Table 4.18.7 (2)" text="" />
          <arrayvalue source="Default" value="Tubesheet material:        SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Tube material:             SA-214 K01807 Wld. tube" text="" />
          <arrayvalue source="Default" value="Shell material:            SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Channel material:          SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Adjacent shell material:   -" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Design temp. tubesheet T = 420 F        Design temp. tubes    Tt = 420 F" text="" />
          <arrayvalue source="Default" value="Design temp. shell    Ts = 420 F        Design temp. channel  Tc = 160 F" text="" />
          <arrayvalue source="Default" value="Shell metal tmp/TubS T's = 292.1 F      Channel metal tmp TS T'c = 90.5 F" text="" />
          <arrayvalue source="Default" value="TubSh metal tmp at rim T'= 144.5 F      Tubesheet OD           A = 9.875 in" text="" />
          <arrayvalue source="Default" value="TubSh mod.elasticity   E = 27779998 psi Shell mod.elasticity  Es = 27779998 psi" text="" />
          <arrayvalue source="Default" value="Channel mod.elast.    Ec = 28984616 psi Tube mod.elas. at Tt  Et = 27779998 psi" text="" />
          <arrayvalue source="Default" value="TubSh allowable stress S = 20000 psi    Tube mod.elas. at T  Ett = 27779998 psi" text="" />
          <arrayvalue source="Default" value="Tube yield stress    Syt = 22000 psi    Tube allow.Str. at Tt St = 13412 psi" text="" />
          <arrayvalue source="Default" value="Tube exp.depth ratio rho = 1            Tube allow.Str. at T Stt = 13412 psi" text="" />
          <arrayvalue source="Default" value="Tube expanded depth  ltx = 0.4375 in    Eff.tube side groove h'g = 0.0 in" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness    h = 0.4375 in    Unsupported tube span  l = 12.219 in" text="" />
          <arrayvalue source="Default" value="Tube buckling factor   k = 0.8          Unsupp.length lt=k*l  lt = 9.7752 in" text="" />
          <arrayvalue source="Default" value="Center-to-center dis  UL = 1.75 in      Tube pitch             p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="Pass partition groove hg = 0.0 in       Tube outside diam.    dt = 1.125 in" text="" />
          <arrayvalue source="Default" value="Tube side cor.allow.  ct = 0.125 in     Shell side cor.allow. cs = 0.125 in" text="" />
          <arrayvalue source="Default" value="Tube projection      tpr = 0.125 in     Tube corrosion allow.  c = -" text="" />
          <arrayvalue source="Default" value="Outermost tube rad.   ro = 3.6305 in    Tube thickness        tt = 0.083 in" text="" />
          <arrayvalue source="Default" value="Shell all. stress     Ss = 20000 psi    Channel all. stress   Sc = 20000 psi" text="" />
          <arrayvalue source="Default" value="Adj Shell all. str. Ss,1 = -            Gasket diam G1        G1 = 9.375 in" text="" />
          <arrayvalue source="Default" value="Gasket shell diameter Gs = -            Gasket channel diam.  Gc = 9.5 in" text="" />
          <arrayvalue source="Default" value="Shell radius          as = 4.75 in      Channel radius        ac = 4.75 in" text="" />
          <arrayvalue source="Default" value="Shell thickness       ts = 0.1875 in    Channel thickness     tc = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Adjacent shell thk  ts,1 = -            Channel ID            Dc = 10.386 in" text="" />
          <arrayvalue source="Default" value="Shell ID              Ds = 10.386 in    Tube length L         L  = 94.625 in" text="" />
          <arrayvalue source="Default" value="Number of tubes       Nt = 20           Tube length Lt        Lt = 95.5 in" text="" />
          <arrayvalue source="Default" value="Bolt circle            C = 11.5 in      Flange load           W* = 0 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness    h = 0.4375 in    Actual tubesheet thk  ha = 1.0 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Shell design pressure Ps = 50 psi       Tube design pressure Pt  = 50 psi" text="" />
          <arrayvalue source="Default" value="Shell vacuum press.  Psv = 0 psi        Tube vacuum press.  Ptv  = 0 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="*Shell th.ex.coe.alpha's = 6.8842       *Chan.th.ex.coe.alpha'c  = 6.4683" text="" />
          <arrayvalue source="Default" value="*TubSh th.ex.coe. alpha' = 6.589           *(*10**6) in/in/F" text="" />
          <arrayvalue source="Default" value="Poisson's ratio shell vs = 0.3          Poisson's rat. tubes  vt = 0.3" text="" />
          <arrayvalue source="Default" value="Poisson's rat.channel vc = 0.3          Poisson's rat. tubSh   v = 0.3" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Table 4.18.6  Select W* for configuration (C) and design" text="" />
          <arrayvalue source="Default" value="              loading case 2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  W* = 0      = 0 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 1.  Determine Do, Mu, Mu* and h'g from 4.18.6.4(a)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Do = 2 * ro + dt                                                     (4.18.2)" text="" />
          <arrayvalue source="Default" value="     = 2 *3.6305 + 1.125                                     Do = 8.386 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  mu = (p - dt) / p                                                    (4.18.3)" text="" />
          <arrayvalue source="Default" value="     = (1.4062 - 1.125) / 1.4062                             mu = 0.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  d* = MAX[(dt-2*tt*(Ett/E)*(Stt/S)*Rho),(dt-2*tt)]                    (4.18.5)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  = MAX[(1.125- 2*0.083*(27779998/27779998)*( 13412 / 20000 )*   1  ) ," text="" />
          <arrayvalue source="Default" value="        (1.125- 2*0.083)]" text="" />
          <arrayvalue source="Default" value="                                                             d* = 1.0137 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Actual pass lane area, AL                                  AL = 14.68 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  p* = p/SQRT(1-(4*MIN[AL,4*Do*p]/Pi*Do**2))                           (4.18.6)" text="" />
          <arrayvalue source="Default" value="     = 1.4062/SQRT(1-(4*MIN[ AL , 4* 8.386 *1.4062]/Pi* 8.386 **2))" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                             p* = 1.641 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  mu*= (p* - d*) / p*                                                  (4.18.7)" text="" />
          <arrayvalue source="Default" value="     = ( 1.641 - 1.0137)/1.641                              mu* = 0.3823" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  h'g = MAX[(hg-ct),0.0]                                               (4.18.8)" text="" />
          <arrayvalue source="Default" value="      = MAX[( 0.0 - 0.125 ) , 0.0]                          h'g = 0.0 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                      * h'g = 0 for Operating Load Cases" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate ao, ac, as, rhos, rhoc, xs, and xt" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  ao  = Do/2                                                         (4.18.157)" text="" />
          <arrayvalue source="Default" value="      =  8.386 /2                                            ao = 4.193 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  as  = Gc/2                     Configuration (C)                   (4.18.160)" text="" />
          <arrayvalue source="Default" value="      =   9.5  /2                                            as = 4.75 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  ac  = Gc/2                     Configuration (C)                   (4.18.162)" text="" />
          <arrayvalue source="Default" value="      =   9.5  /2                                            ac = 4.75 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  rhos= as/ao                                                        (4.18.164)" text="" />
          <arrayvalue source="Default" value="      =  4.75  / 4.193                                     rhos = 1.1328" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  rhoc= ac/ao                                                        (4.18.165)" text="" />
          <arrayvalue source="Default" value="      =  4.75  / 4.193                                     rhoc = 1.1328" text="" />
          <arrayvalue source="Default" value="  xs  = 1-Nt(dt/2*ao)**2                                             (4.18.166)" text="" />
          <arrayvalue source="Default" value="      = 1- 20 (1.125/ 2* 4.193 )**2                          xs = 0.6401" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  xt  = 1-Nt((dt-2*tt)/2*ao)**2                                      (4.18.167)" text="" />
          <arrayvalue source="Default" value="      = 1- 20 ((1.125- 2*0.083)/ 2* 4.193 )**2               xt = 0.7384" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 2.  Calculate the shell and channel coefficients" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) The shell coefficients for Configuration (C)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                    beta_s = k_s = lambda_s = delta_s = 0" text="" />
          <arrayvalue source="Default" value="(b) The channel coefficients for Configuration (C)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                    beta_c = k_c = lambda_c = delta_c = 0" text="" />
          <arrayvalue source="Default" value="                                  zeta_c = 0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                  CC = CmDelta = CmTheta = CqDelta = CqTheta = 1" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 3.  Calculate h/p and Parameter Xa." text="" />
          <arrayvalue source="Default" value="                  Determine E*/E and v* using paragraph 4.18.6.4(b)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    Layout: Square" text="" />
          <arrayvalue source="Default" value="    Tubesheet thickness    h = 0.4375 in    Tube pitch        p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="    h/p factor           h/p = 0.3111       mu* factor      mu* = 0.3823" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value=" From table 4.18.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    E*/E factor         E*/E = 0.5186       v* factor        v* = 0.1923" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="    Effective Tubesheet Modulus of Elasticity                E* = 14405349 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Xa = [(24*(1-(v*)**2)*Nt*Et*tt*(dt-tt)*ao**2)                      (4.18.183)" text="" />
          <arrayvalue source="Default" value="           / ((E*)*L*h**3)]**0.25" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = [(24*(1-(0.1923 )**2)* 20 *27779998 *0.083*(1.125-0.083)* 4.193 **2)" text="" />
          <arrayvalue source="Default" value="        / ( 14405349 *94.625 *0.4375 **3)]**0.25" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                             Xa = 3.616" text="" />
          <arrayvalue source="Default" value=" Using Xa, Determine Psi1, Psi2, Za, Zd, Zv, Zw, and Zm" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Psi1(Xa)=bei(Xa)+(1-v*)/Xa*ber'(Xa)                  Psi1(Xa) = 1.7606" text="" />
          <arrayvalue source="Default" value="  Psi2(Xa)=ber(Xa)-(1-v*)/Xa*bei'(Xa)                  Psi2(Xa) = -1.5366" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Za = bei'(Xa)*Psi2(Xa)-ber'(Xa)*Psi1(Xa)                   Za = 4.033" text="" />
          <arrayvalue source="Default" value="  Zd = (ber(Xa)*Psi2(Xa)+ bei(Xa)*Psi1(Xa))/(Xa**3*Za)       Zd = 0.0333" text="" />
          <arrayvalue source="Default" value="  Zv = (ber'(Xa)*Psi2(Xa)+ bei'(Xa)*Psi1(Xa))/(Xa**2*Za)     Zv = 0.0825" text="" />
          <arrayvalue source="Default" value="  Zw = (ber'(Xa)*ber(Xa)+ bei'(Xa)*bei(Xa))/(Xa**2*Za)       Zw = 0.0825" text="" />
          <arrayvalue source="Default" value="  Zm = (ber'(Xa)**2+bei'(Xa)**2)/(Xa*Za)                     Zm = 0.4421" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 4.  Calculate the following parameters" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  K  = A/Do                                                          (4.18.184)" text="" />
          <arrayvalue source="Default" value="     =  9.875 /  8.386                                        K = 1.178" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  F  = ((1-v*)/E*)*(lambda_s+lambda_c+E*Ln(K))                       (4.18.185)" text="" />
          <arrayvalue source="Default" value="     = ((1-0.1923)/ 14405349  )*(    0   +    0    + 27779998*Ln(1.178))" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                              F = 0.255" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Phi= (1+v*)*F                                                      (4.18.186)" text="" />
          <arrayvalue source="Default" value="     = (1+0.1923)*0.255                                     Phi = 0.3035" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q1 = (rhos-1-Phi*Zv)/(1+Phi*Zm)                                    (4.18.187)" text="" />
          <arrayvalue source="Default" value="     = (1.1328-1-0.3035*0.0825)/(1+0.3035*0.4421)            Q1 = 0.095" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 5.  Calculate the following quantities" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) Calculate omega_s, omega_s*, omega_c, and omega_c*" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_s = rhos*k_s*beta_s*delta_s*(1+h*beta_s)                     (4.18.188)" text="" />
          <arrayvalue source="Default" value="   = 1.1328*   0  *   0  *    0    *(1+ 0.4375  *   0  )" text="" />
          <arrayvalue source="Default" value="                                                        omega_s = 0.0 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_s*= ((ao**2*(rhos**2-1)*(rhos-1))/4)-omega_s                 (4.18.189)" text="" />
          <arrayvalue source="Default" value="   = (( 4.193 **2*(1.1328**2-1)*(1.1328-1))/4)-0.0" text="" />
          <arrayvalue source="Default" value="                                                        omega_s*= 0.1654 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_c = rhoc*k_c*beta_c*(delta_c*(CmDelta + CqDelta*h*beta_c)" text="" />
          <arrayvalue source="Default" value="          -zeta_c*(CmTheta/beta_c + h*CqTheta/2)                     (4.18.190)" text="" />
          <arrayvalue source="Default" value="   = 1.1328*   0   *   0  *(    0    *(1 + 1*0.4375*   0  ) - 0" text="" />
          <arrayvalue source="Default" value="                                                        omega_c = 0.0 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  omega_c*= ao**2[((rhoc**2+1)*(rhoc-1))/4 - (rhos-1)/2]-omega_c     (4.18.191)" text="" />
          <arrayvalue source="Default" value="   =  4.193 **2[((1.1328**2+1)*(1.1328-1))/4 - (1.1328-1)/2]-0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                        omega_c*= 0.1654 in2" text="" />
          <arrayvalue source="Default" value="(b) Calculate gamma_b For Configuration (C)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  gamma_b = (Gc-G1)/Do                                               (4.18.194)" text="" />
          <arrayvalue source="Default" value="          = (  9.5  - 9.375 )/8.386                      gamma_b = 0.0149" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 6.  Calculate the effective pressure Pe" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Pe = Ps-Pt                                                         (4.18.198)" text="" />
          <arrayvalue source="Default" value="     =  50   -   0                                            Pe = 50 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="4.18.9.4 Step 7.  For each loading case check the bending stress" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(a) Calculate Q2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q2 = [(omega_s*)(Ps)-(omega_c*)(Pt)+(gamma_b*(W*))/2*Pi] /         (4.18.201)" text="" />
          <arrayvalue source="Default" value="         (1+Phi*Zm)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="     = [( 0.1654  )( 50  )-( 0.1654  )(  0  )+(0.0149 *   0  )/2*Pi] /" text="" />
          <arrayvalue source="Default" value="         (1+0.3035*0.4421)" text="" />
          <arrayvalue source="Default" value="                                                             Q2 = 7.29" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="(b) Pe not equal to zero, calculate Q3" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Q3 = Q1 + 2*(Q2)/(Pe*ao**2)                                        (4.18.202)" text="" />
          <arrayvalue source="Default" value="     =  0.095 +2*(   7.29   )/(   50    *  4.193 **2)        Q3 = 0.1116" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Determine coefficient Fm (Tbl. 4.18.3 or Fig. 4.18.7 and 4.18.8), where" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                  Controlling x = 2.6762 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation functions Psi1 and Psi2 relative to x" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Psi1(x) = bei(x) + (1-v*)/x * ber'(x)                 Psi1(x) = 1.2868" text="" />
          <arrayvalue source="Default" value="  Psi2(x) = ber(x) - (1-v*)/x * bei'(x)                 Psi2(x) = -0.0811" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate Functions Qm, Qv, and Fm relative to x" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Qm(x) = [bei'(Xa)*Psi2(x)-ber'(Xa)*Psi1(x)]/Za          Qm(x) = 0.8002" text="" />
          <arrayvalue source="Default" value="  Qv(x) = [Psi1(Xa)*Psi2(x)-Psi2(Xa)*Psi1(x)]/(Xa*Za)     Qv(x) = 0.1258" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Fm(x) = [Qv(x) + Q3*Qm(x)] / 2" text="" />
          <arrayvalue source="Default" value="        = [Qv2.6762) + (0.1116 )*Qm2.6762)] / 2           Fm(x) = 0.1076" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Fm = MAX|Fm(x)|                                            Fm = 0.1076" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculate the tubesheet bending stress" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  sigma = Pe*(1.5*Fm/mu*)*(2*ao/(h-h'g))**2                          (4.18.203)" text="" />
          <arrayvalue source="Default" value="        =    50    *(1.5*0.1076/0.3823)*(2* 4.193 /0.4375 -  0.0 ))**2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                          sigma = 7753 psi" text="" />
          <arrayvalue source="Default" value="(c) Acceptance Criteria" text="" />
          <arrayvalue source="Default" value="                                                       |sigma| &lt;= 1.5*S" text="" />
          <arrayvalue source="Default" value="                                                      7753 psi &lt;= 30000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Units: Pressure/stress: psi       Distance: in" text="" />
          <arrayvalue source="Default" value="Controlling case:                            ***" text="" />
          <arrayvalue source="Default" value="  Load case                        1          2          3          4" text="" />
          <arrayvalue source="Default" value="  Factor Q2                        5          7         12          0" text="" />
          <arrayvalue source="Default" value="  Flange load, W*               5642.6        0       5642.6        0" text="" />
          <arrayvalue source="Default" value="  Factor Q3                      0.085      0.112        0          0" text="" />
          <arrayvalue source="Default" value="  Factor Fm                      0.097      0.108      0.066      0.066" text="" />
          <arrayvalue source="Default" value="  Tube-side press, Pt             50          0         50          0" text="" />
          <arrayvalue source="Default" value="  Shell-side press, Ps             0         50         50          0" text="" />
          <arrayvalue source="Default" value="  Effective press., Pe            -50        50          0          0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  TubSh Bending stress           -6979      7753        968         0" text="" />
          <arrayvalue source="Default" value="  Max TubSh Bending st           30000      30000      30000      30000" text="" />
          <arrayvalue source="Default" value="  Min TubSh thk                  0.211     0.2224     0.0786       0.0" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Tubesheet thickness           0.4375     0.4375     0.4375     0.4375" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation of Tubesheet Temperature" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Heat Transfer Coefficients on Tubesheet" text="" />
          <arrayvalue source="Default" value="           Shell-side face     hs = 120.5 Btu/(ft2*h*F)" text="" />
          <arrayvalue source="Default" value="           Tube-side face      ht = 1105.7 Btu/(ft2*h*F)" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet thermal conductivity  k = 34.6 Btu/(ft*h*F)" text="" />
          <arrayvalue source="Default" value="Tubesheet thickness             L = 0.0365 ft         or L = 0.4375 in" text="" />
          <arrayvalue source="Default" value="Tubes pitch                     p = 1.4062 in" text="" />
          <arrayvalue source="Default" value="Tubes inside diameter           d = 0.959 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Metal heat transfer coefficient, unpierced plate, hm = k/L = 948.8 Btu/(ft2*h*F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Layout cross sectional area, a = p**2-Pi/4*d**2               a = 1.255 in2" text="" />
          <arrayvalue source="Default" value="Inside surface of tubes bounding a ligament, A = Pi*d*L       A = 1.318 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Factor K = SQRT(A/a * ht/hm)                                  K = 1.106" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Fin effectiveness of tubesheet ligament, eta" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="         A    [1 + (A/a*K) * TANH(K)]" text="" />
          <arrayvalue source="Default" value="  eta = --- * [---------------------]                       eta = 0.955" text="" />
          <arrayvalue source="Default" value="        a*K   [ (A/a*K) + TANH(K)   ]" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Tubesheet Temperature Profile" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Maximum temperature of shell side fluid, Ts               Ts = 354.2 F" text="" />
          <arrayvalue source="Default" value="   Maximum temperature of tube  side fluid, Tt               Tt = 95 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet temperature (pierced section)" text="" />
          <arrayvalue source="Default" value="   Metal temperature at shell side face" text="" />
          <arrayvalue source="Default" value="     To = Tt + (Ts - Tt) / (1 + Eta * (ht / hs))             To = 121.6 F" text="" />
          <arrayvalue source="Default" value="   Metal temperature at tube side face" text="" />
          <arrayvalue source="Default" value="     TL = Tt + F * (Ts - Tt) / (1 + Eta * (ht / hs))         TL = 103.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Tubesheet temperature T = MAX[To,TL]             (pierced) T = 121.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Tubesheet mean metal temperature" text="" />
          <arrayvalue source="Default" value="     Tmean = Tt+(Ts-Tt)*(Eta-F)/((A/a)*(1+Eta*(ht/hs)))   Tmean = 224.6 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tubesheet rim temperature (unpierced ring)" text="" />
          <arrayvalue source="Default" value="   Metal temperature at shell side face" text="" />
          <arrayvalue source="Default" value="     To = Tt+(Ts-Tt)/(1+(ht/hs)*(1/(1+ht/hm)))               To = 144.5 F" text="" />
          <arrayvalue source="Default" value="   Metal temperature at tube side face" text="" />
          <arrayvalue source="Default" value="     TL = Tt+(Ts-Tt)/((1+ht/hm)+(ht/hs))                     TL = 117.9 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Rim temperature T = MAX[To,TL]                 (unpierced) T = 144.5 F" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="??????" text="" />
        </values>
      </array>
