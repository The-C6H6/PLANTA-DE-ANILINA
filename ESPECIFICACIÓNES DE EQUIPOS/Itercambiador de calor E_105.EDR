          <arrayvalue source="Default" value="Flange shape constants:" text="" />
          <arrayvalue source="Default" value="       K = A/B           = 1.4623        ho = SQ(B*g0)    = 1.3955" text="" />
          <arrayvalue source="Default" value="       T = Fig.2-7.1     = 1.7271      h/ho = h/ho        = 0.7166" text="" />
          <arrayvalue source="Default" value="       Z = Fig.2-7.1     = 2.757          F = Fig.2-7.2   = 0.7639" text="" />
          <arrayvalue source="Default" value="       Y = Fig.2-7.1     = 5.2796         V = Fig.2-7.3   = 0.1402" text="" />
          <arrayvalue source="Default" value="       U = Fig.2-7.1     = 5.8018         f = Fig.2-7.6   = 1.049" text="" />
          <arrayvalue source="Default" value="   g1/g0 = g1/g0         = 2.4667         e = F/ho        = 0.5474" text="" />
          <arrayvalue source="Default" value="       t =               = 0.9375 in" text="" />
          <arrayvalue source="Default" value="       d = U*ho*g0*g0/V  = 2.0301     Alpha = t*e+1.0     = 1.5132" text="" />
          <arrayvalue source="Default" value="    Beta = 1.333*t*e+1.0 = 1.6841     Gamma = Alpha/T     = 0.8762" text="" />
          <arrayvalue source="Default" value="   Delta = t*t*t/d       = 0.4059    Lambda = Gamma+Delta = 1.2821" text="" />
