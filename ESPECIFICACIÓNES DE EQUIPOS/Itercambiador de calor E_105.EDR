          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Overturning moment, OM,  ft-lbf                 OM = F*L = 162" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Wind and Seismic Loads - Effect on Saddles" text="" />
          <arrayvalue source="Default" value="Dist.between saddles                                  Ls = 4.79 ft" text="" />
          <arrayvalue source="Default" value="Saddle width                                           E = 0.78 ft" text="" />
          <arrayvalue source="Default" value="" text="" />
