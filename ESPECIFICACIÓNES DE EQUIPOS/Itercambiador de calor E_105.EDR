          <arrayvalue source="Default" value="Outside radius        Rl = 2.25 in      Radius of hole        Rh = 0.75 in" text="" />
          <arrayvalue source="Default" value="Weld size              n = 0.25 in      Vessel outside radius  R = 5.3805 in" text="" />
          <arrayvalue source="Default" value="Allowable stress      Sa = 15700 psi    Vessel thickness      ta = 0.3125 in" text="" />
          <arrayvalue source="Default" value="Yield stress vessel   Sy = 38000 psi    Empty weight per lug   W = 1195 lbf" text="" />
          <arrayvalue source="Default" value="Distance vessel surface to lug hole                            d = 2.5 in" text="" />
          <arrayvalue source="Default" value="Factor f               f = 0.5 in       Number of lugs        nl = 2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation of allowable lug load, P (minimum of P1 or P2):" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   P1 = Sa*tb / ( 0.33/(Rl-Rh) + 0.76*(Rl+rh)/(Rl-Rh)**2)  = 3182 lbf" text="" />
          <arrayvalue source="Default" value="   P2 = 1.5*Sa*tb*L / ( (10.4*(d+f) /L) + 1 )              = 3340 lbf" text="" />
          <arrayvalue source="Default" value="                                            (P &gt; W)      P = 3182 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation of the minimum required weld size, n" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   n = 6.8 * W * d / l**2 * Sa = 0.0639 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Calculation of the required vessel thickness to resist lug loads, ts" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Equivalent radius of lug, RE = 0.644*(tb*l**2)**(1/3) = 1.1058 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   ts = ( 0.415*SQRT(R)/Sy * ( (1.734*W*(d+f)/(RE**2))+0.75*W/RE ) )**2/3" text="" />
          <arrayvalue source="Default" value="   ts = 0.2814 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="   Minimum reinforcing pad thickness, tp" text="" />
          <arrayvalue source="Default" value="   tpm = ts - ta = -" text="" />
          <arrayvalue source="Default" value="   tp1 = 0.75*ta = -" text="" />
          <arrayvalue source="Default" value="   tp  = MAX[tpm,tp1]" text="" />
          <arrayvalue source="Default" value="                                               Minimum         Actual" text="" />
          <arrayvalue source="Default" value="   Reinforcement pad thickness                 0.0 in         0.0 in" text="" />
          <arrayvalue source="Default" value="   Pad dimension parallel to the lug:          0.0 in         0.0 in" text="" />
          <arrayvalue source="Default" value="   Pad dimension perpendicular to the lug:     0.0 in         0.0 in" text="" />
          <arrayvalue source="Default" value="??????" text="" />
        </values>
      </array>
