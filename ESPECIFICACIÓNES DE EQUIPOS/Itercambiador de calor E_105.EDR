          <arrayvalue source="Default" value="  Base plate moment, M = Q*F/8                             M = 427 lbf*in" text="" />
          <arrayvalue source="Default" value="  Section modulus, Z = A*tb**2/6                           Z = 0.22 in3" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Base plate bending stress, fbc = M/Z                   fbc = 1944 psi" text="" />
          <arrayvalue source="Default" value="                  fbc &lt;= fbcMax = 0.66*fy             fbcMax = 16907 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Base plate with offset web" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="  Distance edge base plate to web, d2                     d2 = 0.25 in" text="" />
          <arrayvalue source="Default" value="  Weld leg size, base to web, ww                          ww = 0.25 in" text="" />
          <arrayvalue source="Default" value="  Web length, Lw = A - 2*j                                Lw = 8.875 in" text="" />
          <arrayvalue source="Default" value="  Ribs length, Lr = n*(G-tw)                              Lr = 3.75 in" text="" />
          <arrayvalue source="Default" value="  Overall length, L = Lw + Lr                              L = 12.625 in" text="" />
          <arrayvalue source="Default" value="  Unit load, fu = Q/L  lbf/in                             fu = 67.66" text="" />
