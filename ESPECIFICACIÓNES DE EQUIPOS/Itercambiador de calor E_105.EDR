          <arrayvalue source="Default" value="Total turn around area = AF+AH                               A = 49.9 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Flow area of one tube = Pi*((tod-2*tt)/2)**2                at = 0.7223 in2" text="" />
          <arrayvalue source="Default" value="Average flow area per pass = (1/tp)*nt*at                   ap = 7.2 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                      A &gt;= 1.3 *ap" text="" />
          <arrayvalue source="Default" value="                               49.9 in2 &gt;= 9.4 in2" text="" />
          <arrayvalue source="Default" value="" text="" />
        </values>
