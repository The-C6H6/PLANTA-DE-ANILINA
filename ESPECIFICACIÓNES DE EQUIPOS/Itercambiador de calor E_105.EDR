      <array name="DetSupports">
        <uom></uom>
        <values>
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Horizontal Vessels on Saddles" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Saddle material: SA-285 K02801 Grd C Plate" text="" />
          <arrayvalue source="Default" value="Wear plate mtl:  -" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Shell mean radius      R = 5.2867 in    Total force  Q = W + WS = 1580 lbf" text="" />
          <arrayvalue source="Default" value="Weight used            W = 1580 lbf     From wind/seismic    WS = 0 lbf" text="" />
          <arrayvalue source="Default" value="Shell length           L = 85.1875 in   Angle alpha       Alpha = 1.9897    rad" text="" />
          <arrayvalue source="Default" value="Angle beta          Beta = 120    deg   Angle delta       Delta = 1.3963    rad" text="" />
          <arrayvalue source="Default" value="Vessel thickness      TS = 0.3125 in    Wear plate tks.       w = ---" text="" />
          <arrayvalue source="Default" value="Vessel corr.allowance CA = 0.125 in     Vessel thk TS+w-CA  tsw = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Saddle depth           b = 4.0 in       Effective depth      b1 = 5.5532 in" text="" />
          <arrayvalue source="Default" value="Wear plate width      bw = ---          Angle theta       Theta = 120       deg" text="" />
          <arrayvalue source="Default" value="Pressure               P = 50 psi       Inside diameter      ID = 10.386 in" text="" />
          <arrayvalue source="Default" value="Joint efficiency      JE = 0.85         Head joint eff.     JEH = 0.85" text="" />
          <arrayvalue source="Default" value="Front head thickness  TH = 1.1875 in    Rear head thickness  TH = 0.375 in" text="" />
          <arrayvalue source="Default" value="Head diameter          D = 14.0 in      Head corr.allowance CAH = 0.125 in" text="" />
          <arrayvalue source="Default" value="b1 = b+1.56*(R*(TS-CA))**0.5)" text="" />
          <arrayvalue source="Default" value="                                                     Saddle A      Saddle B" text="" />
          <arrayvalue source="Default" value="Loads on saddles             Q =                       854           726    lbf" text="" />
          <arrayvalue source="Default" value="Distance from ref. point     A =                       8.5            8      in" text="" />
          <arrayvalue source="Default" value="Head length                  H =                       ---           ---     in" text="" />
          <arrayvalue source="Default" value="Ratio A/R                  A/R =                     1.6078        1.5132" text="" />
          <arrayvalue source="Default" value="Bending moment factor       K7 =                     0.0529        0.0529" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Shell pressure stress                     PS = P*R/(2*tsw) = 705 psi" text="" />
          <arrayvalue source="Default" value="Fr. head press. stress   = P*D+0.2*P*(TH-CAH)/(2*(TH-CAH)) = ---" text="" />
          <arrayvalue source="Default" value="Re. head press. stress   = P*D+0.2*P*(TH-CAH)/(2*(TH-CAH)) = ---" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Alpha = Pi-(Pi/180)*(Theta/2+Beta/20)   Delta = (Pi/180)*(5*Theta/12+30)" text="" />
          <arrayvalue source="Default" value="S11 = (3*Q*L/(Pi*(TS-CA)*R**2)) S12 = 1-(1-A/L+(R**2-H**2)/(2*A*L))/(1+4*H/3*L)" text="" />
          <arrayvalue source="Default" value="S13 = Pi*(Sin(Delta)/Delta-Cos(Delta))                    S13/S14=1 if shell is" text="" />
          <arrayvalue source="Default" value="S14 = Delta+Sin(Delta)*Cos(Delta)-2*Sin(Delta)**2/Delta           stiffened" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Stresses in psi                                 *** Saddles ***" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bending stress at saddle + pressure               A         B     Allowable" text="" />
          <arrayvalue source="Default" value="  S1 = S11*(4*A/L)*S12*S13/S14 + PS             1038       948      17000" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bending stress at midspan + pressure" text="" />
          <arrayvalue source="Default" value="  S21 = (1+2*(R**2-H**2)/L**2)/(1+4*H/(3*L))" text="" />
          <arrayvalue source="Default" value="  S2  = S11*(S21-4*A/L) + PS                    1377      1299      17000" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tangential shear in shell (unstiffened)" text="" />
          <arrayvalue source="Default" value="  S41 = Sin(Alpha)/" text="" />
          <arrayvalue source="Default" value="      (Pi-Alpha+Sin(Alpha)*Cos(Alpha))" text="" />
          <arrayvalue source="Default" value="  S42 = L-H-2*A/(L+H)" text="" />
          <arrayvalue source="Default" value="  S4  = (Q/R*(TS-CA))*S42*S41                    807       697      16000" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Tangential shear in shell (stiffened)" text="" />
          <arrayvalue source="Default" value="  S61 = Sin(Alpha) * Cos(Alpha)" text="" />
          <arrayvalue source="Default" value="  S62 = (Sin(Alpha)/Pi)*(Alpha-S61)/" text="" />
          <arrayvalue source="Default" value="        (Pi-Alpha+S61)" text="" />
          <arrayvalue source="Default" value="  S6  = (Q/(R*(TS-CA)))*S62                      ---       ---       ---" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Circumferential stress at horn, psi" text="" />
          <arrayvalue source="Default" value="  S71 = 3 * Q * K7 / (2 * tsw**2)" text="" />
          <arrayvalue source="Default" value="  S72 = 4*tsw*(b+1.56*(R*tsw)**0.5)" text="" />
          <arrayvalue source="Default" value="  S7  = -Q/S72 - S71                            -2131     -1812    -25000" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Ring compression in shell over saddle, psi" text="" />
          <arrayvalue source="Default" value="  S91 = 1+Cos(Alpha)/" text="" />
          <arrayvalue source="Default" value="      (Pi-Alpha+Sin(Alpha)*Cos(Alpha))" text="" />
          <arrayvalue source="Default" value="  S92 = (TS-CA)*(B+1.56*(R*(TS-CA))**0.5)" text="" />
          <arrayvalue source="Default" value="  S9  = (Q/S92) * S91                            624       530      16100" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Tangential shear stresses in head, psi" text="" />
          <arrayvalue source="Default" value="  S51 = Sin(Alpha) * Cos(Alpha)" text="" />
          <arrayvalue source="Default" value="  S52 = (Sin(Alpha)/Pi)*(Alpha-S51)/" text="" />
          <arrayvalue source="Default" value="          (Pi-Alpha+S51)" text="" />
          <arrayvalue source="Default" value="  S5  = (Q/(12*R*(TH-CAH)))*S52                  ---       ---       ---" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Head stresses, psi" text="" />
          <arrayvalue source="Default" value="  S81 = 3*Q/(8*12*R*(TH-CAH))" text="" />
          <arrayvalue source="Default" value="  S82 = (Sin(Alpha))**2" text="" />
          <arrayvalue source="Default" value="  S83 = Pi-Alpha+Sin(Alpha)*Cos(Alpha)" text="" />
          <arrayvalue source="Default" value="  S8  = S81*(S82/S83)                            ---       ---" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Head stresses + pressure, psi" text="" />
          <arrayvalue source="Default" value="  S8 + PH                                        ---       ---       ---" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Saddle Geometry Verification" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Saddle width        A = 9.375 in        Saddle depth       F = 4.0 in" text="" />
          <arrayvalue source="Default" value="Rib thickness       J = 0.25 in         Web thickness     tw = 0.25 in" text="" />
          <arrayvalue source="Default" value="Base plate thk     tb = 0.375 in        Wear plate thk   tra = 0.0 in" text="" />
          <arrayvalue source="Default" value="Min saddle height   h = 6.75 in         Corr.Shell thk    ts = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Number of ribs      n = 1               Vessel CL to base  B = 12.1305 in" text="" />
          <arrayvalue source="Default" value="Angle alpha,rad alpha = 1.9897          Angle beta, rad beta = 2.0944" text="" />
          <arrayvalue source="Default" value="Angle theta,rad theta = 2.0944          Rib depth          G = 4.0 in" text="" />
          <arrayvalue source="Default" value="Yield saddle mtl   fy = 25360 psi       Inside radius     Ri = 5.193 in" text="" />
          <arrayvalue source="Default" value="                                        Outside radius    Ro = 5.3805 in" text="" />
          <arrayvalue source="Default" value="Max. load/saddle   Qm = 854 lbf         Friction factor   mu = 0.1" text="" />
