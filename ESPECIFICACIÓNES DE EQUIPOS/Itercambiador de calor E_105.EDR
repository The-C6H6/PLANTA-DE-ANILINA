      <array name="DetFlanges">
        <uom></uom>
        <values>
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Component:  Front Head Flng At Cov" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="ASME Section VIII-1 2023 ------- App.2 Bolted Flange With Ring Type Gaskets" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Flange type: Integral tapered hub - ASME fig.2-4(6)" text="" />
          <arrayvalue source="Default" value="Flange material: SA-105 K03504 Forgings" text="" />
          <arrayvalue source="Default" value="Pressure (Des+Sta+Pe) PI = 50 psi       Design temperature     T = 160 F" text="" />
          <arrayvalue source="Default" value="Design pressure,         = 50 psi       Static head presssure    = 0 psi" text="" />
          <arrayvalue source="Default" value="Ext. design pressure  PE = 0 psi        B1 = B+g1 or B+go     B1 = -" text="" />
          <arrayvalue source="Default" value="Inside corr. allow   CAI = 0.125 in     Outside corr. all.   CAO = 0.0 in" text="" />
          <arrayvalue source="Default" value="Stress (operating)   SFO = 20000 psi    Stress (atmos.)      SFA = 20000 psi" text="" />
          <arrayvalue source="Default" value="Outside diameter       A = 15.1875 in   Inside spherical rad.  L = -" text="" />
          <arrayvalue source="Default" value="Inside diameter        B = 10.386 in    Hub thickness         g1 = 0.4625 in" text="" />
          <arrayvalue source="Default" value="Bolt circle diameter   C = 13.5625 in   Hub tks. at attach.   go = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Mean gasket diameter   G = 11.9375 in   Weld leg/hub length    h = 1.0 in" text="" />
          <arrayvalue source="Default" value="Hub to bolt circle     R = 1.1258 in    Bolt circle to OD      E = 0.8125 in" text="" />
          <arrayvalue source="Default" value="Flange thickness       t = 0.9375 in" text="" />
          <arrayvalue source="Default" value="Overlay thickness     OL = -" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket material: Flat Metal Jacket Fiber Iron" text="" />
          <arrayvalue source="Default" value="Gasket outside dia.  ODG = 12.3125 in   Gasket width           N = 0.375 in" text="" />
          <arrayvalue source="Default" value="Gasket thickness     tks = 0.125 in     Gasket eff. width      b = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Gasket seating stress  y = 7600 psi     Gasket factor          m = 3.75" text="" />
          <arrayvalue source="Default" value="Gasket rib seat. str. yr = 7600 psi     Gasket rib factor     mr = 3.75" text="" />
          <arrayvalue source="Default" value="Gasket unit stress    Sg = 6442 psi     W = 0.0 in      factor f = 0.0 in" text="" />
          <arrayvalue source="Default" value="Gasket rib length    Rib = 11.5625 in   Seating width         bo = 0.1875 in" text="" />
          <arrayvalue source="Default" value="Gasket rib eff width  Br = 0.125 in      (Table 2-5.2  facing 1a/1b  Col. II )" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bolt material: SA-193 G41400 Grd B7 Bolt(&lt;= 2 1/2)" text="" />
          <arrayvalue source="Default" value="Bolt diameter         db = 0.75 in      No. of bolts           n = 12" text="" />
          <arrayvalue source="Default" value="Bolt root area      Area = 0.302 in2    Sg = Ab*Sa/((Pi/4)*((do-f)**2-di**2))" text="" />
          <arrayvalue source="Default" value="Bsmax = 2*db+6*t/(m+0.5)                Actual bolt spacing   Bs = 3.5507 in" text="" />
          <arrayvalue source="Default" value="Max bolt spacing   BsMax = 2.8235 in    Min bolt spacing   BsMin = 1.75 in" text="" />
          <arrayvalue source="Default" value="Cf = SQRT(Bs/Bsmax)   Cf = 1.121        Cf used               Cf = 1.121" text="" />
          <arrayvalue source="Default" value="Stress (operating)    SB = 25000 psi    Stress (atmos.)       SA = 25000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bolting calculations:" text="" />
          <arrayvalue source="Default" value="  Joint-contact compr. load  HP = 6.2832*b*G*PI*m+2*Br*mr*PI*RIB=     3179 lbf" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end force       H = 0.7854*G*G*PI                 =     5596 lbf" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end force       He = 0.7854*G*G*PE                =        0 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="  Min. calc. bolt load      WM1 = HP+H                          =     8775 lbf" text="" />
          <arrayvalue source="Default" value="  Min. used bolt load       WM1 = max of 2 mating flanges       =     8775 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="Minimum bolt load           WM2 = 3.1416*b*G*y+Br*yr*RIB        =    64426 lbf" text="" />
          <arrayvalue source="Default" value="Min. used bolt load         WM2 = max of 2 mating flanges       =    64426 lbf" text="" />
          <arrayvalue source="Default" value="Required bolt area           AM = WM2/SA or WM1/SB              =     2.58 in2" text="" />
          <arrayvalue source="Default" value="Available bolt area          AB = No.Bolt*Area                  =     3.62 in2" text="" />
          <arrayvalue source="Default" value="Ratio of bolt areas       AB/AM = 1.406" text="" />
          <arrayvalue source="Default" value="Design bolt load              W = 0.5*(AM+AB)*SA                =    77513 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Minimum gasket width       NMIN = AB*SA/(6.283*y*G)             =    0.1589 in" text="" />
          <arrayvalue source="Default" value="Gasket compression stress  Gcst = AB*SA/((Pi*G*N)+(Br*RIB))     =     5842 psi" text="" />
          <arrayvalue source="Default" value="Design Bolt Tightening Moment   = W*0.2*db/n                    =   969 lbf*in" text="" />
          <arrayvalue source="Default" value="Bolt Tightening friction factor = 0.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Loads:                   Integral Flange Calculations" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end load       HD = 0.785*B*B*PI    =    4236 lbf" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end load       HDe= 0.785*B*B*PE    =       0 lbf" text="" />
          <arrayvalue source="Default" value="  Gasket load                HG = WM1-H           =    3179 lbf" text="" />
          <arrayvalue source="Default" value="  Result. hydrostatic force  HT = H-HD            =    1360 lbf" text="" />
          <arrayvalue source="Default" value="  Result. hydrostatic force  HTe= He-HDe          =       0 lbf" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="  Gasket load                HG = W               =   77513 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="  Hydrostatic lever arm      hd = R+0.5*g1        = 1.357 in" text="" />
          <arrayvalue source="Default" value="  Gasket load lever arm      hg = (C-G)/2         = 0.8125 in" text="" />
          <arrayvalue source="Default" value="  Result. hydro. lever arm   ht = (R+g1+hg)/2     = 1.2004 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="  Gasket load lever arm      hg = (C-G)/2         = 0.8125 in" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="  Hydrostatic moment         MD = HD*hd           =    5748 lbf*in" text="" />
          <arrayvalue source="Default" value="  Gasket moment              MG = HG*hg           =    2583 lbf*in" text="" />
          <arrayvalue source="Default" value="  Result. hydro. moment      MT = HT*ht           =    1633 lbf*in" text="" />
          <arrayvalue source="Default" value="  Total flange moment       MOP = MD+MG+MT        =    9964 lbf*in" text="" />
          <arrayvalue source="Default" value="                    MOPe = HDe(hd-hg)+HTe(ht-hg)  =       0 lbf*in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="  Total flange moment       MGS = W*hg            =   62979 lbf*in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bolt spacing correction      (TEMA RCB-11.23) Cf= 1.121" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Flange shape constants:" text="" />
          <arrayvalue source="Default" value="       K = A/B           = 1.4623        ho = SQ(B*g0)    = 1.3955" text="" />
          <arrayvalue source="Default" value="       T = Fig.2-7.1     = 1.7271      h/ho = h/ho        = 0.7166" text="" />
          <arrayvalue source="Default" value="       Z = Fig.2-7.1     = 2.757          F = Fig.2-7.2   = 0.7639" text="" />
          <arrayvalue source="Default" value="       Y = Fig.2-7.1     = 5.2796         V = Fig.2-7.3   = 0.1402" text="" />
          <arrayvalue source="Default" value="       U = Fig.2-7.1     = 5.8018         f = Fig.2-7.6   = 1.049" text="" />
          <arrayvalue source="Default" value="   g1/g0 = g1/g0         = 2.4667         e = F/ho        = 0.5474" text="" />
          <arrayvalue source="Default" value="       t =               = 0.9375 in" text="" />
          <arrayvalue source="Default" value="       d = U*ho*g0*g0/V  = 2.0301     Alpha = t*e+1.0     = 1.5132" text="" />
          <arrayvalue source="Default" value="    Beta = 1.333*t*e+1.0 = 1.6841     Gamma = Alpha/T     = 0.8762" text="" />
          <arrayvalue source="Default" value="   Delta = t*t*t/d       = 0.4059    Lambda = Gamma+Delta = 1.2821" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Stress calculations:" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Total flange moment       M = Cf*MGS              =   70625 lbf*in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                         Allowable stress:" text="" />
          <arrayvalue source="Default" value="Long. hub     SH = (f*M)/(Lambda*g1**2*B)  =   26012 psi 1.5*SFA =   30000 psi" text="" />
          <arrayvalue source="Default" value="Radial        SR = Beta*M/(Lambda*t**2*B)  =   10163 psi     SFA =   20000 psi" text="" />
          <arrayvalue source="Default" value="Tangential   ST1 = M*Y/(t**2*B)-(Z*SR)     =   12828 psi     SFA =   20000 psi" text="" />
          <arrayvalue source="Default" value="  (greater)  ST2 = (SH+SR)/2 or (SH+ST1)/2 =   19420 psi     SFA =   20000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Total flange moment       M = Cf*MOP              =   11173 lbf*in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="                                                         Allowable stress:" text="" />
          <arrayvalue source="Default" value="Long. hub     SH = (f*M)/(Lambda*g1**2*B)  =    4115 psi 1.5*SFO =   30000 psi" text="" />
          <arrayvalue source="Default" value="Radial        SR = Beta*M/(Lambda*t**2*B)  =    1608 psi     SFO =   20000 psi" text="" />
          <arrayvalue source="Default" value="Tangential   ST1 = M*Y/(t**2*B)-(Z*SR)     =    2029 psi     SFO =   20000 psi" text="" />
          <arrayvalue source="Default" value="  (greater)  ST2 = (SH+SR)/2 or (SH+ST1)/2 =    3072 psi     SFO =   20000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
          <arrayvalue source="Default" value="Component:  Channel Cover" text="" />
          <arrayvalue source="Default" value="ASME Section VIII-1 2023 ------- UG-34 Unstayed Flat Heads and Covers" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="--- Calculations --- Channel Cover Internal Pressure" text="" />
          <arrayvalue source="Default" value="Material:  SA-516 K02700 Grd 70 Plate" text="" />
          <arrayvalue source="Default" value="Design pressure        P = 50 psi       Design temperature     T = 160 F" text="" />
          <arrayvalue source="Default" value="Stress (operating)    SO = 20000 psi    Stress (atmos.)       SA = 20000 psi" text="" />
          <arrayvalue source="Default" value="Corr. allowance      CAI = 0.125 in" text="" />
