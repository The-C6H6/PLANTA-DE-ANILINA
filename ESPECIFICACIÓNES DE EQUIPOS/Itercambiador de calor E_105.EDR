          <arrayvalue source="Default" value="Bolt root area      Area = 0.302 in2    Sg = Ab*Sa/((Pi/4)*((do-f)**2-di**2))" text="" />
          <arrayvalue source="Default" value="Bsmax = 2*db+6*t/(m+0.5)                Actual bolt spacing   Bs = 3.5507 in" text="" />
          <arrayvalue source="Default" value="Max bolt spacing   BsMax = 2.8235 in    Min bolt spacing   BsMin = 1.75 in" text="" />
          <arrayvalue source="Default" value="Cf = SQRT(Bs/Bsmax)   Cf = 1.121        Cf used               Cf = 1.121" text="" />
          <arrayvalue source="Default" value="Stress (operating)    SB = 25000 psi    Stress (atmos.)       SA = 25000 psi" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Bolting calculations:" text="" />
          <arrayvalue source="Default" value="  Joint-contact compr. load  HP = 6.2832*b*G*PI*m+2*Br*mr*PI*RIB=     3179 lbf" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end force       H = 0.7854*G*G*PI                 =     5596 lbf" text="" />
          <arrayvalue source="Default" value="  Hydrostatic end force       He = 0.7854*G*G*PE                =        0 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Operating conditions:" text="" />
          <arrayvalue source="Default" value="  Min. calc. bolt load      WM1 = HP+H                          =     8775 lbf" text="" />
          <arrayvalue source="Default" value="  Min. used bolt load       WM1 = max of 2 mating flanges       =     8775 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Gasket seating conditions:" text="" />
          <arrayvalue source="Default" value="Minimum bolt load           WM2 = 3.1416*b*G*y+Br*yr*RIB        =    64426 lbf" text="" />
          <arrayvalue source="Default" value="Min. used bolt load         WM2 = max of 2 mating flanges       =    64426 lbf" text="" />
          <arrayvalue source="Default" value="Required bolt area           AM = WM2/SA or WM1/SB              =     2.58 in2" text="" />
          <arrayvalue source="Default" value="Available bolt area          AB = No.Bolt*Area                  =     3.62 in2" text="" />
          <arrayvalue source="Default" value="Ratio of bolt areas       AB/AM = 1.406" text="" />
          <arrayvalue source="Default" value="Design bolt load              W = 0.5*(AM+AB)*SA                =    77513 lbf" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Minimum gasket width       NMIN = AB*SA/(6.283*y*G)             =    0.1589 in" text="" />
          <arrayvalue source="Default" value="Gasket compression stress  Gcst = AB*SA/((Pi*G*N)+(Br*RIB))     =     5842 psi" text="" />
          <arrayvalue source="Default" value="Design Bolt Tightening Moment   = W*0.2*db/n                    =   969 lbf*in" text="" />
          <arrayvalue source="Default" value="Bolt Tightening friction factor = 0.2" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="?????" text="" />
