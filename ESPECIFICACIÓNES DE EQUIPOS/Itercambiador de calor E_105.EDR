          <arrayvalue source="Default" value="Available bolt area   Ab = 3.624 in2    Factor x per UG-39(d)(2) = 1" text="" />
          <arrayvalue source="Default" value="Bolt stress (oper.)   Sb = 25000 psi    Nominal diameter      ND = 10.136 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Code required cover thickness:" text="" />
          <arrayvalue source="Default" value="   Operating:  t = G*sqrt(x*(C*P/SO*E+1.9*Wo*hg/(SO*E*G**3)))    = 0.4045 in" text="" />
          <arrayvalue source="Default" value="   Bolting:    t = G*sqrt(x*(1.9*Wb*hg/(SA*E*G**3)))             = 0.708 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="TEMA RCB-9.21 (cover deflection)" text="" />
          <arrayvalue source="Default" value="        Y = G*(0.0435*G**3*P+0.5*Sb*Ab*hg)/(ME*tn**3)            = 0.047 in" text="" />
          <arrayvalue source="Default" value="     Ymax = 0.03 in. (0.076 mm) or ND/800 or User specified      = 0.03 in" text="" />
          <arrayvalue source="Default" value="        t = (G*(0.0435*G**3*P+0.5*Sb*Ab*hg)/(ME*Ymax))**.333     = 0.8223 in" text="" />
          <arrayvalue source="Default" value="" text="" />
          <arrayvalue source="Default" value="Thicknesses do NOT include corrosion or recesses." text="" />
